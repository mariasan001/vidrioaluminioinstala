18:["$","$L26",null,{"content":{"slug":"ventanas","eyebrow":"Ventanas de aluminio y cristal","title":"Luz natural","accentTitle":"con mejor confort interior","description":"Diseñamos e instalamos ventanas a medida para mejorar iluminación, ventilación y aislamiento sin perder una lectura visual limpia.","image":{"src":"/img/ventanas/hero_web.webp","mobileSrc":"/img/ventanas/hero_movil.webp","alt":"Ventana moderna de aluminio y cristal instalada en espacio residencial"},"details":[{"title":"Para recámaras","icon":"balcony","description":"Ventanas que ayudan a controlar luz, ventilación y privacidad en espacios de descanso."},{"title":"Para salas","icon":"deck","description":"Aberturas amplias que conectan el interior con la vista y hacen más ligero el ambiente."},{"title":"Para áreas de trabajo","icon":"stairs","description":"Soluciones que mejoran iluminación natural, ventilación y concentración durante el día."}],"quality":{"eyebrow":"Calidad de la ventana","title":"Materiales pensados","accentTitle":"para luz y aislamiento","description":"Cada ventana se define según el claro, la orientación, la ventilación necesaria y el nivel de confort que requiere el espacio.","image":{"src":"/img/ventanas/calidad.webp","alt":"Detalle de ventana de aluminio y cristal con instalación precisa"},"points":[{"title":"Iluminación natural","icon":"shield","description":"Permite aprovechar mejor la entrada de luz sin hacer pesado el espacio."},{"title":"Medición precisa","icon":"height","description":"Consideramos claros, niveles y encuentros para que la ventana ajuste correctamente."},{"title":"Ventilación adecuada","icon":"sparkles","description":"El sistema se define según la circulación de aire que necesita cada área."},{"title":"Aislamiento","icon":"wrench","description":"Ayuda a mejorar el confort térmico y acústico según el tipo de ventana y cristal."},{"title":"Acabados a elegir","icon":"swatch","description":"Perfiles y tonos que se integran al estilo del proyecto sin saturar