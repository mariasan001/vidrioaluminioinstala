18:["$","$L26",null,{"content":{"slug":"puertas","eyebrow":"Puertas de aluminio, cristal y herrería","title":"Accesos ligeros","accentTitle":"para conectar el espacio","description":"Diseñamos e instalamos puertas a medida pensadas para mejorar el acceso, conservar luz y acompañar el flujo diario del proyecto.","image":{"src":"/img/puertas/hero_web.webp","mobileSrc":"/img/puertas/hero_movil.webp","alt":"Puerta moderna de aluminio y cristal instalada en acceso residencial"},"details":[{"title":"Para accesos","icon":"stairs","description":"Puertas que resuelven la entrada con seguridad, presencia y una apertura cómoda."},{"title":"Para interiores","icon":"balcony","description":"Soluciones que separan ambientes sin cortar la luz ni hacer pesado el recorrido."},{"title":"Para exteriores","icon":"deck","description":"Accesos resistentes y bien integrados para terrazas, patios y frentes de uso constante."}],"quality":{"eyebrow":"Calidad de la puerta","title":"Materiales pensados","accentTitle":"para uso diario","description":"Cada puerta se define según el claro, la forma de apertura, el nivel de seguridad y el acabado que mejor acompaña el espacio.","image":{"src":"/img/puertas/beneficios.webp","alt":"Detalle de puerta de aluminio y cristal con instalación limpia"},"points":[{"title":"Apertura cómoda","icon":"shield","description":"El sistema se elige según el paso, la frecuencia de uso y la circulación del espacio."},{"title":"Medición precisa","icon":"height","description":"Consideramos claros, niveles y encuentros para que la puerta ajuste correctamente."},{"title":"Luz y vista","icon":"sparkles","description":"El cristal ayuda a mantener iluminación y conexión visual entre áreas."},{"title":"Seguridad adecuada","icon":"wrench","description":"La solución se define con la firmeza necesaria para el uso residencial o comercial."},{"title":"Acabados a elegir","icon":"swatch","description":"Perfiles, tonos y detalles que se integran al estilo del proyecto."},{"title":"Ins